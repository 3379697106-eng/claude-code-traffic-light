    }],
    "Elicitation": [{
      "matcher": "",
      "hooks": [{ "type": "command", "command": "powershell -ExecutionPolicy Bypass -File \"你的路径/status_writer.ps1\" -State waiting" }]
    }],
    "PostToolUse": [{
      "matcher": "",
